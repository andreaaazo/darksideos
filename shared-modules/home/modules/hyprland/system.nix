{
  # Hyprland global settings namespace.
  wayland.windowManager.hyprland.settings = {
    # Miscellaneous compositor behavior toggles.
    misc = {
      # BRANDING LOGO
      # Hides the Hyprland logo to keep startup clean
      disable_hyprland_logo = true;
      # SPLASH SCREEN
      # Skips splash screen rendering to reduce startup overhead
      disable_splash_rendering = true;
      # DEFAULT WALLPAPER OVERRIDE
      # Prevents Hyprland from forcing a built-in wallpaper
      force_default_wallpaper = 0;
    };
  };
}
